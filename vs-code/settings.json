{
	"editor.fontFamily": "Jetbrains Mono, Berkeley Mono, Monolisa Pro-2",
	"editor.fontSize": 16,
	"window.zoomLevel": 1,
	"terminal.integrated.fontSize": 16,
	"terminal.integrated.fontFamily": "Cascadia Code",
	"workbench.tree.indent": 15,
	"prettier.tabWidth": 4,
	"npm.packageManager": "bun",
	"editor.bracketPairColorization.enabled": false,
	"editor.formatOnType": true,
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"breadcrumbs.enabled": false,
	"editor.cursorBlinking": "expand",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.smoothScrolling": true,
	"editor.semanticHighlighting.enabled": true,
	"terminal.integrated.minimumContrastRatio": 1,
	"scm.diffDecorations": "all",
	"editor.hover.enabled": "on",
	"editor.matchBrackets": "never",
	"workbench.tips.enabled": false,
	"editor.colorDecorators": false,
	"git.decorations.enabled": false,
	"workbench.startupEditor": "none",
	"editor.lightbulb.enabled": "off",
	"editor.selectionHighlight": false,
	"editor.overviewRulerBorder": false,
	"editor.renderLineHighlight": "none",
	"editor.occurrencesHighlight": "off",
	"problems.decorations.enabled": false,
	"editor.renderControlCharacters": false,
	"editor.hideCursorInOverviewRuler": true,
	"editor.gotoLocation.multipleDefinitions": "goto",
	"editor.gotoLocation.multipleDeclarations": "goto",
	"workbench.editor.enablePreviewFromQuickOpen": false,
	"editor.gotoLocation.multipleImplementations": "goto",
	"editor.gotoLocation.multipleTypeDefinitions": "goto",
	"editor.copyWithSyntaxHighlighting": false,
	"diffEditor.ignoreTrimWhitespace": false,
	"editor.emptySelectionClipboard": false,
	"workbench.editor.enablePreview": false,
	"window.newWindowDimensions": "inherit",
	"editor.multiCursorModifier": "ctrlCmd",
	"files.trimTrailingWhitespace": true,
	"diffEditor.renderSideBySide": false,
	"editor.detectIndentation": false,
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"workbench.editor.showTabs": "multiple",
	"editor.minimap.enabled": true,
	"editor.lineNumbers": "on",
	"prettier.jsxSingleQuote": true,
	"explorer.compactFolders": false,
	"editor.suggestSelection": "recentlyUsedByPrefix",
	"js/ts.updateImportsOnFileMove.enabled": "always",
	"js/ts.preferences.importModuleSpecifier": "non-relative",
	"workbench.activityBar.location": "top",
	"js/ts.suggest.classMemberSnippets.enabled": false,
	"editor.snippets.codeActions.enabled": false,
	"editor.wordWrap": "on",
	"editor.wordWrapColumn": 110,
	"editor.guides.indentation": true,
	"editor.guides.highlightActiveIndentation": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"workbench.colorCustomizations": {
		"editorIndentGuide.background1": "#99999920",
		"editorIndentGuide.activeBackground1": "#99999940",
		"[Vira*]": {
			"toolbar.activeBackground": "#80CBC426",
			"button.background": "#80CBC4",
			"button.hoverBackground": "#80CBC4cc",
			"extensionButton.separator": "#80CBC433",
			"extensionButton.background": "#80CBC414",
			"extensionButton.foreground": "#80CBC4",
			"extensionButton.hoverBackground": "#80CBC433",
			"extensionButton.prominentForeground": "#80CBC4",
			"extensionButton.prominentBackground": "#80CBC414",
			"extensionButton.prominentHoverBackground": "#80CBC433",
			"activityBarBadge.background": "#80CBC4",
			"activityBar.activeBorder": "#80CBC4",
			"activityBarTop.activeBorder": "#80CBC4",
			"list.inactiveSelectionIconForeground": "#80CBC4",
			"list.activeSelectionForeground": "#80CBC4",
			"list.inactiveSelectionForeground": "#80CBC4",
			"list.highlightForeground": "#80CBC4",
			"sash.hoverBorder": "#80CBC480",
			"list.activeSelectionIconForeground": "#80CBC4",
			"scrollbarSlider.activeBackground": "#80CBC480",
			"editorSuggestWidget.highlightForeground": "#80CBC4",
			"textLink.foreground": "#80CBC4",
			"progressBar.background": "#80CBC4",
			"pickerGroup.foreground": "#80CBC4",
			"tab.activeBorder": "#80CBC4",
			"notificationLink.foreground": "#80CBC4",
			"editorWidget.resizeBorder": "#80CBC4",
			"editorWidget.border": "#80CBC4",
			"settings.modifiedItemIndicator": "#80CBC4",
			"panelTitle.activeBorder": "#80CBC4",
			"breadcrumb.activeSelectionForeground": "#80CBC4",
			"menu.selectionForeground": "#80CBC4",
			"menubar.selectionForeground": "#80CBC4",
			"editor.findMatchBorder": "#80CBC4",
			"selection.background": "#80CBC440",
			"statusBarItem.remoteBackground": "#80CBC414",
			"statusBarItem.remoteHoverBackground": "#80CBC4",
			"statusBarItem.remoteForeground": "#80CBC4",
			"notebook.inactiveFocusedCellBorder": "#80CBC480",
			"commandCenter.activeBorder": "#80CBC480",
			"chat.slashCommandForeground": "#80CBC4",
			"chat.avatarForeground": "#80CBC4",
			"activityBarBadge.foreground": "#000000",
			"button.foreground": "#000000",
			"statusBarItem.remoteHoverForeground": "#000000",
		},
	},
	"files.associations": {
		"*.css": "tailwindcss",
	},
	"editor.quickSuggestions": {
		"strings": true,
	},
	"js/ts.preferences.autoImportFileExcludePatterns": [
		"@radix-ui/react-a*",
		"@radix-ui/react-o*",
		"@radix-ui/react-b*",
		"@radix-ui/react-p*",
		"@radix-ui/react-d*",
		"@radix-ui/react-q*",
		"@radix-ui/react-c*",
		"@radix-ui/react-r*",
		"@radix-ui/react-e*",
		"@radix-ui/react-s*",
		"@radix-ui/react-f*",
		"@radix-ui/react-t*",
		"@radix-ui/react-g*",
		"@radix-ui/react-u*",
		"@radix-ui/react-h*",
		"@radix-ui/react-v*",
		"@radix-ui/react-j*",
		"@radix-ui/react-w*",
		"@radix-ui/react-k*",
		"@radix-ui/react-x*",
		"@radix-ui/react-l*",
		"@radix-ui/react-y*",
		"@radix-ui/react-m*",
		"@radix-ui/react-z*",
		"@radix-ui/react-n*",
	],
	"tailwindCSS.classFunctions": ["tw", "clsx", "tw\\.[a-z-]+"],
	"prettier.experimentalTernaries": true,
	"tailwindCSS.emmetCompletions": true,
	"editor.unicodeHighlight.allowedCharacters": {
		"’": true,
	},
	"editor.codeActionsOnSave": {
		"source.fixAll": "always",
		"source.organizeImports": "always",
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"files.autoSave": "afterDelay",
	"editor.indentSize": "tabSize",
	"prettier.printWidth": 120,
	"js/ts.suggest.objectLiteralMethodSnippets.enabled": false,
	"editor.insertSpaces": false,
	"prettier.useTabs": true,
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true,
	},
	"vue.editor.templateInterpolationDecorators": false,
}
