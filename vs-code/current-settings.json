{
	"editor.fontFamily": "JetBrains Mono",
	"editor.fontWeight": "350",
	"editor.fontSize": 16,
	"editor.tabSize": 4,
	// "editor.lineHeight": 1.5,
	"editor.stickyScroll.enabled": false,
	"explorer.compactFolders": false,
	"editor.insertSpaces": false,
	"editor.renderWhitespace": "none",
	"editor.detectIndentation": false,
	"editor.indentSize": "tabSize",
	"editor.autoIndent": "advanced",
	"editor.suggestSelection": "recentlyUsedByPrefix",
	"editor.semanticHighlighting.enabled": "configuredByTheme",
	"editor.formatOnType": false,
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.cursorBlinking": "expand",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.bracketPairColorization.enabled": false,
	"editor.smoothScrolling": true,
	"editor.occurrencesHighlight": "off",
	"editor.selectionHighlight": false,
	"terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
	"terminal.integrated.fontSize": 15,
	"workbench.tips.enabled": false,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"js/ts.format.placeOpenBraceOnNewLineForFunctions": true,
	"js/ts.format.placeOpenBraceOnNewLineForControlBlocks": true,
	"js/ts.preferences.importModuleSpecifier": "shortest",
	"js/ts.updateImportsOnFileMove.enabled": "always",
	"js/ts.suggest.autoImports": true,
	"js/ts.suggest.enabled": true,
	"chat.agent.enabled": false,
	"chat.disableAIFeatures": true,
	"files.autoSave": "onWindowChange",
	"extensions.ignoreRecommendations": true,
	"editor.links": false,
	"vue.editor.templateInterpolationDecorators": false,
	"vue.format.script.enabled": false,
	"vue.format.style.enabled": true,
	"vue.format.template.enabled": false,
	"workbench.tree.indent": 10,
	"[vue]": {
		"editor.defaultFormatter": "Vue.volar"
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"[css]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"workbench.startupEditor": "none",
	"workbench.statusBar.visible": false,
	"files.trimTrailingWhitespace": true,
	"update.showReleaseNotes": false,
	"workbench.colorTheme": "Dark Modern+",
}
