{
    "workbench.colorTheme": "Dark Modern",
    "editor.fontFamily": "DejaVu Sans Mono",
    "editor.fontSize": 16,
    "editor.tabSize": 4,
    "editor.lineHeight": 1.5,
    "explorer.compactFolders": false,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.indentSize": "tabSize",
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "editor.formatOnType": false,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.bracketPairColorization.enabled": false,
    "editor.smoothScrolling": true,
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "workbench.tips.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "js/ts.format.placeOpenBraceOnNewLineForFunctions": true,
    "js/ts.format.placeOpenBraceOnNewLineForControlBlocks": true,
    "js/ts.preferences.importModuleSpecifier": "shortest",
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "js/ts.suggest.autoImports": true,
    "js/ts.suggest.enabled": true,
    "chat.agent.enabled": false,
    "chat.autopilot.enabled": false,
    "chat.disableAIFeatures": true,
    "files.autoSave": "onWindowChange",
    "extensions.ignoreRecommendations": true,
    "editor.links": false,
    "vue.editor.templateInterpolationDecorators": false,
    "vue.format.script.enabled": true,
    "vue.format.style.enabled": true,
    "vue.format.template.enabled": true,
    "workbench.tree.indent": 10,
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll": "always",
        "source.organizeImports": "always",
        "source.removeUnusedImports": "always",
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "variable.other.readwrite",
                    "variable.other.constant",
                    "meta.var-single-variable.expr.js variable.other.readwrite.js"
                ],
                "settings": {
                    "foreground": "#9CDCFE"
                }
            }
        ]
    },
    "editor.defaultFormatter": "Vue.volar",
    "workbench.startupEditor": "none"
}
