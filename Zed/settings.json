{
    "preferred_line_length": 120,
    "soft_wrap": "preferred_line_length",
    "git_panel": {
        "dock": "right",
        "tree_view": false,
    },
    "outline_panel": {
        "indent_size": 20.0,
    },
    "disable_ai": true,
    "telemetry": {
        "diagnostics": true,
        "metrics": false,
    },
    "diagnostics": {
        "include_warnings": true,
        "inline": {
            "enabled": true,
        },
    },
    "session": {
        "trust_all_worktrees": true,
    },
    "base_keymap": "VSCode",
    "ui_font_size": 18,
    "ui_font_family": "Berkeley Mono",
    "buffer_font_family": "Berkeley Mono",
    "buffer_font_size": 18,
    "icon_theme": {
        "mode": "dark",
        "light": "Colored Zed Icons Theme Light",
        "dark": "Colored Zed Icons Theme Dark",
    },
    "theme": {
        "mode": "dark",
        "light": "Github Plus Light",
        "dark": "Base16 Ashes",
    },
    "indent_guides": {
        "enabled": true,
    },
    "formatter": "auto",
    "code_actions_on_format": {
        "source.removeUnusedImports": true,
        "source.organizeImports": true,
    },
    "format_on_save": "on",
    "project_panel": {
        "dock": "right",
        "indent_guides": {
            "show": "always",
        },
        "indent_size": 15.0,
        "folder_icons": false,
        "auto_fold_dirs": false,
        "git_status": false,
    },
    "tab_size": 4,
    "languages": {
        "TypeScript": {
            "language_servers": ["typescript-language-server", "!vtsls"],
        },
        "TSX": {
            "language_servers": ["typescript-language-server", "tailwindcss-language-server", "!vtsls"],
        },
        "JavaScript": {
            "language_servers": ["typescript-language-server", "!vtsls"],
        },
    },
    "lsp": {
        "tailwindcss-language-server": {
            "settings": {
                "classFunctions": ["cva", "cx", "clsx"],
            },
        },
    },
}
