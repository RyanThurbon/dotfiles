{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "lightYellow",
                    "style": "plain",
                    "template": "{{ .UserName }} ",
                    "type": "session"
                },
                {
                    "style": "plain",
                    "type": "path",
                    "foreground": "cyan",
                    "options": {
                        "style": "agnoster_full",
                        "max_depth": 3,
                        "home_icon": "~"
                    },
                    "template": "<#ffffff>in</> {{ .Folder }} "
                },
                {
                    "foreground": "#ff94df",
                    "options": {
                        "branch_icon": " <#ff94df><b>\ue0a0 </b></>"
                    },
                    "style": "plain",
                    "template": "<#ffffff>on</> {{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "lightGreen",
                    "style": "plain",
                    "template": "\u276f",
                    "type": "text"
                }
            ],
            "type": "prompt"
        }
    ],
    "final_space": true,
    "version": 4
}
